# ------------------------------------------------------------------
# Grant Radar — local environment template
# ------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored, do NOT commit real keys.
#
# Three groups of variables:
#   1. REQUIRED        — without these, the API route will error
#   2. ANTHROPIC       — pick exactly ONE of the two patterns
#   3. RESERVED        — pre-staged for the upcoming shareable-link
#                        export feature (see docs/export-plan.md)
# ------------------------------------------------------------------


# ============== 1. REQUIRED ==============

# GrantGuru REST API base URL. Use the production URL unless you have
# explicit access to a sandbox.
GRANTGURU_API_URL=https://grantguru.com/api/v1

# Your GrantGuru partner API key (starts with `gg_live_` in prod).
# Obtained from the GrantGuru partner portal. Treat like a password.
GRANTGURU_API_KEY=gg_live_replace_me

# Pinned GUID of the shared GrantGuru user that all radar searches run
# through. Provisioning this user manually (org name "GG Radar", no
# sector / fundingSource / fundingType) keeps results unbiased — see
# docs/grantguru-integration.md.
#
# If unset, the server will lazy-register a user on the first search
# and log the resolved GUID to stdout — paste that GUID back here to
# skip lazy SSO on subsequent boots.
GG_RADAR_USER_GUID=00000000-0000-0000-0000-000000000000


# ============== 2. ANTHROPIC (pick ONE) ==============

# Option A — Vercel AI Gateway (recommended for Vercel deployments).
# Provides usage analytics, fallbacks, and shared billing. Set this
# OR ANTHROPIC_API_KEY, not both.
AI_GATEWAY_API_KEY=ai-gateway_replace_me

# Option B — direct Anthropic API key from console.anthropic.com.
# Uncomment if you're not using AI Gateway.
# ANTHROPIC_API_KEY=sk-ant-replace_me


# ============== 3. RESERVED (for the export feature) ==============
# These aren't read by the current code, but the upcoming shareable
# /r/[id] feature will use them. Safe to leave unset for now.

# Supabase project — used to persist radar results so they can be
# shared via a short-link URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...replace_me

# Server-side service role key. Bypasses RLS so the API route can
# insert new shareable-result rows without an authenticated user.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...replace_me
